def production_constraints(x):
    P, B, S = x
    # قيد طاقة الماكينة
    g4 = P * S - 20000  # الطاقة القصوى
    # قيد زمن الدورة
    g5 = 60/S - 0.5  # زمن الدورة الأدنى
    return [g4, g5]
